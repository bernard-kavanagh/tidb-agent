# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# db9 PostgreSQL connection string — run `./db9 db connect --url` after login
DB9_CONNECTION_STRING=postgresql://user:password@host:port/dbname

# Scraping config
SCRAPER_DELAY=1.5          # seconds between requests (be polite)
MAX_COMPANIES_PER_COUNTRY=25
MIN_FIT_SCORE=5            # only store leads with score >= this

# Dashboard
DASHBOARD_PORT=8000
